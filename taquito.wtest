import objetos.*

describe "Pelota pateada de taquito"{
    method initialize(){
        game.cellSize(40)
	    game.width(15)
	    game.height(10)
        pelota.position(game.at(3,5))
        lionel.position(game.at(3,5))
    }
    test "Lionel patea la pelota de taquito"{
        //assert
        assert.equals(game.at(3,5), lionel.position())
        assert.equals(game.at(3,5), pelota.position())
        //act
        lionel.patearDeTaquito()
        //assert
        assert.equals(game.at(1,5), pelota.position())
        assert.equals(game.at(3,5), lionel.position())
    }
    test "Lionel intenta patear la pelota de taquito pero no puede "{
        //act
        pelota.position(game.at(4,5))
        //assert
        assert.equals(game.at(3,5), lionel.position())
        assert.equals(game.at(4,5), pelota.position())
        assert.throwsException({lionel.patearDeTaquito()})
    }
}